{
  "name": "@gaia/runtime",
  "private": true,
  "type": "module",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "import": "./src/index.ts"
    },
    "./paths": {
      "types": "./src/paths.ts",
      "import": "./src/paths.ts"
    },
    "./run-read-api": {
      "types": "./src/run-read-api.ts",
      "import": "./src/run-read-api.ts"
    },
    "./server-workflows": {
      "types": "./src/server-workflows.ts",
      "import": "./src/server-workflows.ts"
    },
    "./factory-run-read-api": {
      "types": "./src/factory-run-read-api.ts",
      "import": "./src/factory-run-read-api.ts"
    },
    "./test-support": {
      "types": "./src/test-support.ts",
      "import": "./src/test-support.ts"
    }
  },
  "scripts": {
    "build": "tsdown",
    "check": "tsc --noEmit",
    "test": "vitest run",
    "test:codex-smoke": "GAIA_CODEX_APP_SERVER_SMOKE=1 vitest run src/codex-app-server-smoke.test.ts"
  },
  "dependencies": {
    "@effect/platform-node": "^4.0.0-beta.93",
    "@gaia/core": "workspace:*",
    "effect": "^4.0.0-beta.93",
    "nanoid": "^5.1.16",
    "playwright": "^1.61.1"
  },
  "devDependencies": {
    "@effect/vitest": "^4.0.0-beta.93",
    "@types/node": "^24.0.14",
    "tsdown": "^0.22.3",
    "typescript": "^6.0.3",
    "vitest": "^4.1.9"
  }
}
