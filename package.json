{
  "name": "gaia",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "turbo run build",
    "check": "turbo run check && pnpm lint && pnpm format:check && pnpm test:tooling && pnpm test:effect-epoch && pnpm test:baseline-docs && pnpm test:agent-workspaces && pnpm test:schema-contracts && pnpm schema-contracts:audit",
    "dev": "turbo run dev",
    "format": "oxfmt --config oxfmt.config.ts --write \"apps/**/*.{js,jsx,ts,tsx,mjs,cjs}\" \"packages/**/*.{js,jsx,ts,tsx,mjs,cjs}\" \"examples/**/*.{js,jsx,ts,tsx,mjs,cjs}\" \"scripts/**/*.{js,jsx,ts,tsx,mjs,cjs}\" oxlint.config.ts oxlint.audit.config.ts oxfmt.config.ts",
    "format:check": "oxfmt --config oxfmt.config.ts --check \"apps/**/*.{js,jsx,ts,tsx,mjs,cjs}\" \"packages/**/*.{js,jsx,ts,tsx,mjs,cjs}\" \"examples/**/*.{js,jsx,ts,tsx,mjs,cjs}\" \"scripts/**/*.{js,jsx,ts,tsx,mjs,cjs}\" oxlint.config.ts oxlint.audit.config.ts oxfmt.config.ts",
    "gaia": "pnpm --filter @gaia/cli gaia",
    "lint": "oxlint --config oxlint.config.ts apps packages examples scripts oxlint.config.ts oxlint.audit.config.ts oxfmt.config.ts",
    "lint:audit": "oxlint --config oxlint.audit.config.ts apps packages examples scripts",
    "opensrc:effect": "opensrc path --cwd . effect",
    "postinstall": "./scripts/ensure-effect-source.sh",
    "schema-contracts:audit": "node scripts/audit-schema-contracts.mjs",
    "test": "turbo run test",
    "test:agent-workspaces": "node scripts/verify-agent-workspace-provenance.mjs",
    "test:baseline-docs": "node scripts/verify-baseline-docs.mjs",
    "test:effect-epoch": "node scripts/verify-effect-dependency-epoch.mjs",
    "test:schema-contracts": "node scripts/verify-schema-contract-rules.mjs && node scripts/verify-schema-contract-ownership.mjs",
    "test:tooling": "node scripts/verify-tooling-sorting.mjs",
    "tooling:doctor": "ultracite doctor"
  },
  "devDependencies": {
    "opensrc": "^0.7.3",
    "oxfmt": "0.58.0",
    "oxlint": "1.73.0",
    "turbo": "^2.10.3",
    "typescript": "6.0.3",
    "ultracite": "7.9.3"
  },
  "packageManager": "pnpm@11.7.0"
}
